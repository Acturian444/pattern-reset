rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Let It Out posts - public read, authenticated write
    match /letitout-posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null 
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 500
        && (request.resource.data.truthNumber is number || request.resource.data.truthNumber == null);
      // Allow post author to update (e.g. mark replies read), and any authenticated user
      // to update for adding replies, felt count, etc.
      allow update: if request.auth != null;
    }
    
    // User posts - same rules
    match /user-posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null 
        && request.auth.uid == resource.data.userId;
    }
    
    // Reports - authenticated only
    match /reports/{reportId} {
      allow read, write: if request.auth != null;
    }
    
    // Common Ground applications - authenticated create only (anonymous auth)
    match /commonGroundApplications/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
    
    // Counters collection for Truth numbering
    match /counters/{counterId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Relationship quiz — profile per anonymous (or future linked) uid
    // Own read required: client reads profile before batch write (merge + createdAt / customerStatus).
    match /quizProfiles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && (!request.resource.data.keys().hasAny(['email'])
          || request.resource.data.email == null
          || (request.resource.data.email is string && request.resource.data.email.size() <= 320))
        && (!request.resource.data.keys().hasAny(['name'])
          || request.resource.data.name == null
          || (request.resource.data.name is string && request.resource.data.name.size() <= 120))
        && (!request.resource.data.keys().hasAny(['latestPatternKey'])
          || request.resource.data.latestPatternKey == null
          || (request.resource.data.latestPatternKey is string && request.resource.data.latestPatternKey.size() <= 80));
    }

    match /quizProfiles/{userId}/submissions/{submissionId} {
      allow read: if false;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.source is string
        && request.resource.data.source.size() <= 120
        && request.resource.data.patternKey is string
        && request.resource.data.patternKey.size() <= 80
        && request.resource.data.quizResultVersion is string
        && request.resource.data.quizResultVersion.size() <= 64;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && resource.data.patternKey == request.resource.data.patternKey
        && resource.data.createdAt == request.resource.data.createdAt
        && resource.data.quizResultVersion == request.resource.data.quizResultVersion
        && resource.data.source == request.resource.data.source;
      allow delete: if false;
    }

    match /quizProfiles/{userId}/events/{eventId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.eventType is string
        && request.resource.data.eventType.size() <= 64;
      allow update, delete: if false;
    }

    // Weekly Reset email capture (home, liamsaysit bio) — email, source, createdAt; anonymous create only
    match /weeklyResetSignups/{id} {
      allow create: if request.auth != null
        && request.resource.data.keys().size() == 3
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 320
        && (request.resource.data.source == 'home' || request.resource.data.source == 'liamsaysit')
        && request.resource.data.keys().hasOnly(['email', 'source', 'createdAt']);
      allow read, update, delete: if false;
    }

    match /intakeSubmissions/{intakeId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.paymentStatus == 'pending_checkout'
        && request.resource.data.offerId is string
        && request.resource.data.offerId.size() <= 64
        && request.resource.data.entryPath is string
        && request.resource.data.entryPath.size() <= 32;
      // Client may attach Stripe Checkout session id while still pending_checkout (server webhook completes payment).
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && resource.data.paymentStatus == 'pending_checkout'
        && request.resource.data.paymentStatus == 'pending_checkout'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkoutStartedAt', 'checkoutSessionId', 'updatedAt']);
      allow delete: if false;
    }
    
    // Default rule - deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 