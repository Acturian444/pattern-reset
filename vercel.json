{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/pattern-reset-system",
      "destination": "/philosophy.html"
    },
    {
      "source": "/pattern-reset-system/",
      "destination": "/philosophy.html"
    },
    {
      "source": "/create-checkout-session",
      "destination": "/server.js"
    },
    {
      "source": "/api/verify-checkout",
      "destination": "/server.js"
    },
    {
      "source": "/api/common-ground-google-form",
      "destination": "/server.js"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "commongroundsocialclub.com"
        }
      ],
      "destination": "https://mypatternreset.com/common-ground.html",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.commongroundsocialclub.com"
        }
      ],
      "destination": "https://mypatternreset.com/common-ground.html",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "resetmypattern.com"
        }
      ],
      "destination": "https://mypatternreset.com/$1",
      "permanent": true
    },
    {
      "source": "/home",
      "destination": "/home.html",
      "permanent": false
    },
    {
      "source": "/home/",
      "destination": "/home.html",
      "permanent": false
    },
    {
      "source": "/home-v2",
      "destination": "/home.html",
      "permanent": true
    },
    {
      "source": "/home-v2/",
      "destination": "/home.html",
      "permanent": true
    },
    {
      "source": "/home-v2.html",
      "destination": "/home.html",
      "permanent": true
    },
    {
      "source": "/philosophy.html",
      "destination": "/pattern-reset-system",
      "permanent": true
    },
    {
      "source": "/philosophy",
      "destination": "/pattern-reset-system",
      "permanent": true
    },
    {
      "source": "/philosophy/",
      "destination": "/pattern-reset-system",
      "permanent": true
    },
    {
      "source": "/legal",
      "destination": "/legal.html",
      "permanent": true
    },
    {
      "source": "/legal/",
      "destination": "/legal.html",
      "permanent": true
    },
    {
      "source": "/liamsaysit",
      "destination": "/liamsaysit.html",
      "permanent": false
    },
    {
      "source": "/liamsaysit/",
      "destination": "/liamsaysit.html",
      "permanent": false
    },
    {
      "source": "/product/breakup-course",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/product/breakup-course.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/product/breakup-course/",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/course/breakup-course",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/course/breakup-course.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/course/breakup-course/",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/letitout",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/letitout.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/letitout/",
      "destination": "/",
      "permanent": false
    }
  ]
} 