# Copy to .env for local `node server.js` (never commit .env)
# Vercel: set the same names under Project → Settings → Environment Variables
#
# Testing without real charges:
# 1) Stripe Dashboard → toggle "Test mode" (top right)
# 2) Create product + price in TEST mode → copy price_… (test prices start with price_ too)
# 3) Use sk_test_… and pk_test_… from Developers → API keys (test mode)
# 4) From repo root: node server.js → open http://localhost:3000/personal-relationship-read.html
# Do not mix sk_test with a LIVE price id or pk_live.

STRIPE_SECRET_KEY=
# Publishable key (pk_live_… or pk_test_…) — same Stripe account + mode as STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=
# Personal Relationship Read — prefer explicit price (price_…). Optional: set prod id to auto-pick first one-time price.
STRIPE_PRICE_PERSONAL_RELATIONSHIP_READ=
STRIPE_PRODUCT_PERSONAL_RELATIONSHIP_READ=
# Stripe → Developers → Webhooks → Signing secret (whsec_…)
STRIPE_WEBHOOK_SECRET=
# Firebase Admin JSON (single line) for server-side Firestore updates after payment. Project: pattern-reset.
# Vercel: paste full service account JSON as one line.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Calendly webhook signing key — Calendly Dashboard → Integrations → Webhooks → "Create"
# Used by /api/calendly-webhook to verify invitee.created / invitee.canceled events for the $197 1:1 call.
CALENDLY_WEBHOOK_SIGNING_KEY=
# Quiz → Google Sheet mirror (/api/quiz-google-form-sync). When "true", every request must pass
# X-Firebase-AppCheck (requires RECAPTCHA in App Check + same key in js/config/firebase-config.js + Admin JSON).
# Default false: optional App Check verification when token is sent.
QUIZ_GOOGLE_SYNC_REQUIRE_APP_CHECK=false
